// UltraQC — Nextflow configuration

// Default parameters
params {
    input      = null          // Path to input FASTQ file(s), e.g. "assets/test_data/*.fastq.gz"
    outdir     = "results"     // Where to publish outputs
    use_fastp  = false         // Set to true to trim reads with fastp before FastQC
    threads    = 2             // CPU threads per process
}

// Profiles: choose one with -profile <name>
profiles {

    standard {
        // Runs processes locally WITHOUT Docker (tools must be in PATH)
        process.executor = 'local'
    }

    docker {
        // Runs every process inside a Docker container
        docker.enabled    = true
        docker.runOptions = '-u $(id -u):$(id -g)'  // avoid root-owned output files
        process.executor  = 'local'
    }

    test {
        // Small test run using bundled SE samplesheet
        params.input  = "${projectDir}/assets/samplesheet_se.csv"
        params.outdir = "results_test"
    }

    test_pe {
        // Small test run using bundled PE samplesheet
        params.input  = "${projectDir}/assets/samplesheet_pe.csv"
        params.outdir = "results_test_pe"
    }
}

// Capture pipeline execution reports (disable if rendering fails on your platform)
timeline {
    enabled = false
}
report {
    enabled = false
}
